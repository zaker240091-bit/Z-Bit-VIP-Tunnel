#!/bin/bash

REPO="https://raw.githubusercontent.com/zaker240091-bit/z-bit-vip-tunnel/main/media/"
# fixhap fix Haproxy
clear
echo -e " -------------------------"
echo -e "    Fix Haproxy & Nginx            "
echo -e " ------------------------- "
echo -e ""
echo -e " Install by zaker240091-bit 082328013583 082328013583 "
echo -e ""
read -p " Masukin Domainya : " -e domain

rm -fr /etc/xray/domain
echo "${domain}" > /etc/xray/domain
systemctl stop haproxy
systemctl stop nginx
wget -O /etc/haproxy/haproxy.cfg "https://raw.githubusercontent.com/zaker240091-bit/z-bit-vip-tunnel/main/media/haproxy.cfg" >/dev/null 2>&1
wget -O /etc/nginx/conf.d/xray.conf "https://raw.githubusercontent.com/zaker240091-bit/z-bit-vip-tunnel/main/media/xray.conf" >/dev/null 2>&1
sed -i "s/xxx/${domain}/g" /etc/haproxy/haproxy.cfg
sed -i "s/xxx/${domain}/g" /etc/nginx/conf.d/xray.conf
curl ${REPO}nginx.conf > /etc/nginx/nginx.conf

cat /etc/xray/xray.crt /etc/xray/xray.key | tee /etc/haproxy/hap.pem

systemctl reload nginx
systemctl reload haproxy